{
  "placeholder": "⚡ invoke...",
  "prompt": "➜ ",
  "terminal": "alacritty",
  "scrollbar_policy": "auto",
  "icons": true,
  "icon_size": 22,
  "max_entries": 7,
  "show_sub_text": true,

  "theme": {
    "name": "frankenstein",

    "background":        "#101614",
    "border_color":      "#2a4a38",
    "border_width":      2,
    "border_radius":     12,
    "shadow":            true,
    "shadow_color":      "#08100d",

    "input_bg":          "#182320",
    "input_color":       "#f2ecd9",
    "input_placeholder": "#6f9f88",
    "prompt_color":      "#7cffc4",

    "item_bg":           "#182320",
    "item_color":        "#f2ecd9",
    "item_active_bg":    "#2f5f4b",
    "item_active_color": "#f2ecd9",
    "item_border_radius": 8,

    "sub_text_color":    "#8fdcbb",
    "sub_text_active_color": "#dff8ec",

    "width": 640,
    "margin_top": 120
  }
}
